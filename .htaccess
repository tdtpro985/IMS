Options -Indexes

# Protect sensitive file types
<FilesMatch "\.(sql|log|env|md)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Block direct access to config/includes/modules/db directories
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Route /register to register_intern.php
    RewriteRule ^register$ register_intern.php [L,QSA]

    # Block sensitive directories
    RewriteRule ^(config|includes|modules|db)/ - [F,L]
</IfModule>
